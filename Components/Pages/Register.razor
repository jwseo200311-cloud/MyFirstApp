@page "/register"
@rendermode InteractiveServer
@using MyFirstApp.Data
@using MyFirstApp.Models
@inject AppDbContext Db
@inject NavigationManager Navigation

<PageTitle>회원가입</PageTitle>

<h1>회원가입</h1>

<div style="max-width: 400px;">
    <div class="mb-3">
        <label class="form-label">아이디</label>
        <input class="form-control" @bind="username" placeholder="아이디 입력" />
    </div>

    <div class="mb-3">
        <label class="form-label">비밀번호</label>
        <input type="password" class="form-control" @bind="password" placeholder="비밀번호 입력" />
    </div>

    <button class="btn btn-primary" @onclick="HandleRegister">가입하기</button>

    @if (!string.IsNullOrEmpty(message))
    {
        <p class="mt-3" style="color: @messageColor;">@message</p>
    }
</div>

@code {
    private string username = "";
    private string password = "";
    private string message = "";
    private string messageColor = "red";

    private async Task HandleRegister()
    {
        // 1. 빈 칸 검사
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            message = "아이디와 비밀번호를 모두 입력하세요.";
            messageColor = "red";
            return;
        }

        // 2. 중복 아이디 검사
        var exists = Db.Users.Any(u => u.Username == username);
        if (exists)
        {
            message = "이미 사용 중인 아이디입니다.";
            messageColor = "red";
            return;
        }

        // 3. 비밀번호 해싱 후 저장
        var newUser = new User
        {
            Username = username,
            PasswordHash = BCrypt.Net.BCrypt.HashPassword(password),
            CreatedAt = DateTime.Now
        };

        Db.Users.Add(newUser);
        await Db.SaveChangesAsync();

        message = "회원가입 성공! 로그인 페이지로 이동합니다.";
        messageColor = "green";
    }
}