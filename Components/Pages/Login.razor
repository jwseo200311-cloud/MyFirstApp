@page "/login"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using MyFirstApp.Data
@using MyFirstApp.Models
@inject AppDbContext Db
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation

<PageTitle>로그인</PageTitle>

<h1>로그인</h1>

<div style="max-width: 400px;">
    <EditForm Model="this" OnValidSubmit="HandleLogin" FormName="loginForm">
        <div class="mb-3">
            <label class="form-label">아이디</label>
            <InputText class="form-control" @bind-Value="username" />
        </div>

        <div class="mb-3">
            <label class="form-label">비밀번호</label>
            <InputText type="password" class="form-control" @bind-Value="password" />
        </div>

        <button type="submit" class="btn btn-primary">로그인</button>
    </EditForm>

    @if (!string.IsNullOrEmpty(message))
    {
        <p class="mt-3" style="color: red;">@message</p>
    }
</div>

@code {
    [SupplyParameterFromForm]
    private string? username { get; set; }

    [SupplyParameterFromForm]
    private string? password { get; set; }

    private string message = "";

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            message = "아이디와 비밀번호를 입력하세요.";
            return;
        }

        var user = Db.Users.FirstOrDefault(u => u.Username == username);
        if (user == null)
        {
            message = "존재하지 않는 아이디입니다.";
            return;
        }

        bool valid = BCrypt.Net.BCrypt.Verify(password, user.PasswordHash);
        if (!valid)
        {
            message = "비밀번호가 틀렸습니다.";
            return;
        }

        // 로그인 성공 → 쿠키에 사용자 정보 저장
        var claims = new List<Claim>
        {
            new Claim(ClaimTypes.Name, user.Username)
        };
        var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        var principal = new ClaimsPrincipal(identity);

        var httpContext = HttpContextAccessor.HttpContext;
        await httpContext!.SignInAsync(
            CookieAuthenticationDefaults.AuthenticationScheme,
            principal);

        Navigation.NavigateTo("/", forceLoad: true);
    }
}