@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
    <AuthorizeView>
        <Authorized>
            <span class="me-3">@context.User.Identity?.Name 님</span>
            <form action="/logout" method="post" style="display:inline;">
                <AntiforgeryToken />
                <button type="submit" class="btn btn-link p-0">로그아웃</button>
            </form>
        </Authorized>
        <NotAuthorized>
            <a href="login">로그인</a>
            <a href="register" class="ms-3">회원가입</a>
        </NotAuthorized>
    </AuthorizeView>
    <a href="https://learn.microsoft.com/aspnet/core/" target="_blank" class="ms-3">About</a>
</div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
